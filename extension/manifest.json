{
  "manifest_version": 3,
  "name": "Idetic",
  "version": "0.1.0",
  "description": "Keyboard-first AI-assisted Anki card creation from the browser.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Idetic",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:1455/*",
    "https://chatgpt.com/backend-api/codex/*",
    "https://auth.openai.com/oauth/token"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "mac": "MacCtrl+Shift+I"
      },
      "description": "Open Idetic"
    }
  }
}
